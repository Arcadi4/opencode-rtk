{
  "name": "@4rcadia/opencode-rtk",
  "version": "0.1.0",
  "description": "OpenCode plugin that proxies shell commands through rtk to reduce LLM token consumption.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "rtk",
    "rust-token-killer",
    "shell",
    "llm",
    "token-reduction"
  ],
  "author": "4rcadia",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Arcadi4/opencode-rtk.git"
  },
  "homepage": "https://github.com/Arcadi4/opencode-rtk#readme",
  "bugs": {
    "url": "https://github.com/Arcadi4/opencode-rtk/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.0.5",
      "onFail": "download"
    }
  },
  "type": "module",
  "dependencies": {
    "@opencode-ai/plugin": "^1.14.39",
    "tree-sitter-pwsh": "^0.38.0",
    "unbash": "^3.0.0",
    "web-tree-sitter": "^0.26.8"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
}
